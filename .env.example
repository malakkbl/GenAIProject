APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=true

DATASET_NAME=XJCEO/bloomberg_financial_news_120k
DATASET_SPLIT=train
DATASET_SUBSET_SIZE=5000

LLM_BACKEND=ollama
LLM_MODEL=mistral-nemo
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=350
OLLAMA_URL=http://localhost:11434

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

GRAPH_FILE=backend/graph_store.graphml
